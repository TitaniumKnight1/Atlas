# Maintainer release build secrets — copy to .env.release and fill in locally.
# .env.release is gitignored; never commit the real DSN.
#
#   cp .env.release.example .env.release    # macOS / Linux
#   copy .env.release.example .env.release  # Windows
#
# Used by scripts/build_backend_sidecar.py (and Tauri beforeBuildCommand) to bake
# the Sentry DSN into distributed sidecar binaries. Source/contributor builds
# without this file still succeed with no baked DSN.

ATLAS_SENTRY_DSN=https://<public-key>@<org>.ingest.sentry.io/<project-id>
